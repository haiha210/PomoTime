{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LearnTime",
  "version": "0.1.0",
  "identifier": "com.learntime.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": ".."
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LearnTime",
        "width": 1280,
        "height": 840,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "msi", "nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
