{
  "name": "pomotime",
  "version": "0.1.0",
  "private": true,
  "description": "PomoTime desktop app (Linux/Windows) using Tauri 2",
  "scripts": {
    "dev:web": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "build:web": "vite build && node -e \"require('fs').copyFileSync('app-config.js','dist/app-config.js')\"",
    "preview:web": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "dev": "tauri dev",
    "build": "node scripts/build-desktop.cjs",
    "build:deb": "node scripts/build-desktop.cjs",
    "build:windows": "node scripts/build-desktop.cjs",
    "build:windows:docker": "bash scripts/build-windows-docker.sh",
    "tauri": "tauri",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepush:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && npm run test:all",
    "lint:frontend": "tsc --noEmit",
    "lint:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:rust": "npm run build:web && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run typecheck && npm run test && npm run test:rust",
    "task:complete": "bash scripts/task_complete.sh"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "react-select": "^5.10.2"
  }
}
